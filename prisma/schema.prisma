// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER 
  ADMIN
}

model User{
  id Int @id @default(autoincrement())
  username String @unique
  email String @unique
  mobileNumber String @unique
  password String 
  createdAt DateTime @default(now())
  bookings Booking[]
  refreshToken String?
  role Role @default(USER)
  seatLock SeatLock[]
}

model Train {
  id Int @id @default(autoincrement())
  trainNumber Int @unique
  trainName String 
  sourceStation String
  destinationStation String
  coaches Coach[]
  schedules Schedule[]
}

model Schedule{
  id Int @id @default(autoincrement())
  sourcePlatformId Int
  destinationPlatformId Int
  trainId Int 
  sourcePlatform      Platform @relation("source", fields: [sourcePlatformId], references: [id])
  destinationPlatform Platform @relation("destination", fields: [destinationPlatformId], references: [id])
  train Train @relation(fields: [trainId] , references: [id])
  arrivalTime DateTime @default(now())
  departureTime DateTime 
  date DateTime
  booking Booking[]
  seatLock SeatLock[]
}

model Station {
  id Int @id @default(autoincrement())
  stationName String
  stationCode String @unique
  platform Platform[]
}


model Platform {
  id Int @id @default(autoincrement())
  platformNumber Int
  stationId Int
  station Station @relation(fields: [stationId] , references: [id])
  departureSchedules Schedule[] @relation("source")
  arrivalSchedules   Schedule[] @relation("destination")
}

model Coach{
  id Int @id @default(autoincrement())
  coachNumber String 
  coachType String 
  trainId Int 
  price Int @default(0)
  train Train @relation(fields: [trainId], references: [id])
  seat Seat[]
}

model Seat{
  id Int @id @default(autoincrement())
  seatNumber Int
  seatName String
  coachId Int 
  coach Coach @relation(fields: [coachId] , references: [id])
  seatLock SeatLock[]
}

enum bookingStatus {
  HELD
  BOOKED
  CANCELLED
}

model Booking{
  id Int @id @default(autoincrement())
  userId Int 
  scheduleId Int
  user User @relation(fields: [userId] , references: [id])
  schedule Schedule @relation(fields: [scheduleId] , references: [id])
  status bookingStatus @default(HELD)
  bookingAt DateTime @default(now())
  payment Payment[]
  seatLock SeatLock[]
  passengerInfo PassengerInfo[]
  pnr String? @unique
  createdAt DateTime
}


model Payment{
  id Int @id @default(autoincrement())
  bookingId Int @unique
  booking Booking @relation(fields: [bookingId] , references: [id])
  status String @default("Pending")
  amount Int
  createdAt DateTime
}

enum SeatStatus {
  HELD
  BOOKED
  CANCELLED
}
model SeatLock {
  id Int @id @default(autoincrement())
  seatId Int 
  scheduleId Int
  userId Int 
  bookingId Int
  status SeatStatus @default(HELD)
  heldUntil DateTime
  seat Seat @relation(fields: [seatId] , references: [id])
  user User @relation(fields: [userId] , references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])
  schedule Schedule @relation(fields: [scheduleId] , references: [id])
}

enum passengerGender {
  MALE 
  FEMALE 
  TRANSGENDER
}

model PassengerInfo {
  id Int @id @unique @default(autoincrement())
  passengerName String 
  passengerAge Int 
  passengerGender passengerGender
  bookingId Int 
  booking Booking @relation(fields: [bookingId], references: [id])
}

